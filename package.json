{
  "name": "robotics-tours-dashboard",
  "version": "1.0.0",
  "description": "Dashboard for managing robotics building tours",
  "main": "public/index.html",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "tailwindcss -i src/input.css -o public/styles.css --minify",
    "build:css": "tailwindcss -i src/input.css -o public/styles.css",
    "build:css:watch": "tailwindcss -i src/input.css -o public/styles.css --watch",
    "netlify-dev": "concurrently \"npm run build:css:watch\" \"netlify dev\"",
    "test:workflow": "node tests/workflow-test.js",
    "test:workflow:prod": "TEST_BASE_URL=https://tours.robotics.umich.edu node tests/workflow-test.js",
    "test:workflow:local": "TEST_BASE_URL=http://localhost:8888 node tests/workflow-test.js"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express-session": "^1.18.1",
    "form-data": "^4.0.3",
    "googleapis": "^152.0.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.0.2",
    "node-fetch": "^2.7.0",
    "openid-client": "^6.5.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.10",
    "concurrently": "^9.1.2",
    "netlify-cli": "^22.2.2",
    "tailwindcss": "^4.1.10"
  }
}
